{
  "scripts": {
    "build": "esbuild src/index.ts --bundle --outfile=dist/bundle.js",
    "watch": "esbuild src/index.ts --bundle --outfile=dist/bundle.js --watch",
    "serve": "http-server . -p 3000 -c-1",
    "dev": "concurrently \"npm:watch\" \"npm:serve\""
  },
  "dependencies": {
    "concurrently": "^10.0.3",
    "esbuild": "^0.28.1",
    "http-server": "^14.1.1",
    "typescript": "^6.0.3"
  }
}
